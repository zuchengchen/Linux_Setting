{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "strategy": "summarize",
    "threshold": 0.8,
    "prune_tool_outputs": true
  },
  "provider": {
    "baidu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "BAIDU",
      "options": {
        "baseURL": "https://qianfan.baidubce.com/v2/coding",
        "apiKey": "bce-v3/ALTAKSP-n7ZV8Modq3YzgulAGvdrj/d15157b94a68bbd54edd936aba1378273db9c523"
      },
      "models": {
        "glm-5": {
          "name": "GLM-5",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 128000,
            "output": 4096
          }
        },
        "deepseek-v3.2": {
          "name": "DeepSeek-V3.2",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 64000,
            "output": 8192
          }
        },
        "kimi-k2.5": {
          "name": "Kimi-K2.5",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "minimax-m2.5": {
          "name": "MiniMax-M2.5",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 204800,
            "output": 131072
          }
        }
      }
    },
    "baishan": {
      "npm": "@ai-sdk/anthropic",
      "name": "BAISHAN",
      "options": {
        "baseURL": "https://api.edgefn.net/v1",
        "apiKey": "sk-dnjhZXBnpHiLGQrcF995E4D6E4Bc4142843935F2D4B8Eb70"
      },
      "models": {
        "minimax-m2.5": {
          "name": "MiniMax M2.5",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          },
          "limit": {
            "context": 204800,
            "output": 131072
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          },
          "limit": {
            "context": 202752,
            "output": 16384
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          },
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "plugin": [
    "oh-my-opencode",
    "@tarquinen/opencode-dcp@latest"
  ],
  "permission": {
    "read": {
      "/home/czc/.config/opencode/get-physics-done/*": "allow"
    },
    "external_directory": {
      "/home/czc/.config/opencode/get-physics-done/*": "allow"
    }
  },
  "mcp": {
    "gpd-conventions": {
      "type": "local",
      "command": [
        "/home/czc/.gpd/venv/bin/python",
        "-m",
        "gpd.mcp.servers.conventions_server"
      ],
      "environment": {
        "LOG_LEVEL": "WARNING"
      },
      "enabled": true
    },
    "gpd-errors": {
